/ {
    esb_link {
        compatible = "zmk,split-esb";
        base-address = [E7 D3 9A 5C];

        tx-power-dbm = <8>;
        use-fast-ramp-up;
        retransmit-delay-us = <300>;

        hop-channels = [48 50 52 54 56 58 60 62 64 66 68 70 72 74 76 78 80 82 84 86];
        hop-anchors = [54 68 80];

        peripherals {
            left: peripheral_left {
                pipe = <0>;
                prefix = <0x4B>;
                weight = <1>;
            };
            right: peripheral_right {
                pipe = <1>;
                prefix = <0xC3>;
                weight = <1>;
            };
        };
    };
};