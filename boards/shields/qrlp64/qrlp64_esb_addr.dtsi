/ {
    esb_link {
        compatible = "zmk,split-esb";
        base-address = [E7 D3 9A 5C];

        tx-power-dbm = <8>;
        use-fast-ramp-up;
        retransmit-delay-us = <300>;
        idle-keepalive-ms = <2000>;
        peripheral-timeout-ms = <10000>;
        rssi-floor-dbm = <(-70)>;

        hop-channels = [48 50 52 54 56 58 60 83 85 87 89 91 93 95 97 99];
        hop-anchors = [52 58 89];

        peripherals {
            left: peripheral_left {
                pipe = <0>;
                prefix = <0x4B>;
                weight = <1>;
            };
            right: peripheral_right {
                pipe = <1>;
                prefix = <0xC3>;
                weight = <1>;
            };
        };
    };
};